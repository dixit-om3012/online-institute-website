/* ═══════════════════════════════════════════════
   HERO
   ═══════════════════════════════════════════════ */
.hero{
  min-height:100svh;background:#060606;
  display:flex;align-items:center;
  position:relative;overflow:hidden;padding:0
}
/* Canvas */
.hero-canvas{position:absolute;inset:0;width:100%;height:100%;opacity:.5}
/* Mesh */
.hero-bg-mesh{position:absolute;inset:0;overflow:hidden;pointer-events:none}
.mesh-orb{position:absolute;border-radius:50%;filter:blur(100px);animation:orb-float 12s ease-in-out infinite}
.mesh-orb-1{width:700px;height:700px;background:radial-gradient(circle,rgba(225,29,46,.2),transparent 70%);top:-20%;right:-15%;animation-delay:0s}
.mesh-orb-2{width:500px;height:500px;background:radial-gradient(circle,rgba(225,29,46,.1),transparent 70%);bottom:-10%;left:-10%;animation-delay:-5s;animation-duration:15s}
.mesh-orb-3{width:300px;height:300px;background:radial-gradient(circle,rgba(100,50,50,.15),transparent 70%);top:40%;left:40%;animation-delay:-8s;animation-duration:18s}
@keyframes orb-float{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(-30px,-40px) scale(1.08)}66%{transform:translate(20px,25px) scale(.94)}}
/* Lines */
.hero-lines{
  position:absolute;inset:0;display:flex;gap:calc(100%/6);
  pointer-events:none;overflow:hidden
}
.h-line{
  flex:1;border-right:1px solid rgba(255,255,255,.025);
  animation:line-pulse 4s ease-in-out infinite
}
.h-line:nth-child(odd){animation-delay:.5s}
@keyframes line-pulse{0%,100%{opacity:.3}50%{opacity:.8}}
/* Content */
.hero-content{
  position:relative;z-index:2;
  max-width:var(--max);width:100%;
  margin:0 auto;padding:calc(var(--nav-h) + 5rem) 2rem 7rem
}
/* Eyebrow */
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:.6rem;
  font-size:.75rem;font-weight:500;letter-spacing:.06em;
  color:rgba(255,255,255,.45);
  border:1px solid rgba(255,255,255,.1);border-radius:50px;
  padding:.35rem .95rem;margin-bottom:2.5rem
}
.eyebrow-dot{
  width:7px;height:7px;border-radius:50%;background:var(--red);
  box-shadow:0 0 8px var(--red);
  animation:dot-pulse 2.5s ease-in-out infinite
}
@keyframes dot-pulse{0%,100%{box-shadow:0 0 6px var(--red)}50%{box-shadow:0 0 20px var(--red),0 0 40px rgba(225,29,46,.25)}}
/* Headline */
.hero-headline{
  color:#fff;
  font-size:clamp(3.2rem,8vw,7rem);
  letter-spacing:-.04em;line-height:1.0;
  margin-bottom:1.75rem;max-width:9ch
}
.line-wrap{display:block;overflow:hidden}
.line-text{display:block}
.red-italic{color:var(--red);font-style:italic;font-weight:400}
.hero-brand{
  display:inline-block;
  background:linear-gradient(90deg,#fff 30%,rgba(225,29,46,.85));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text
}
/* Sub */
.hero-sub{
  font-size:clamp(1rem,2vw,1.2rem);
  color:rgba(255,255,255,.45);
  max-width:540px;margin-bottom:2.5rem;line-height:1.65;font-weight:300
}
.br-desktop{display:block}
/* CTA */
.hero-cta{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:3.5rem}
/* Fade-up on load */
.fade-up{opacity:0;transform:translateY(22px);animation:fade-up-anim .8s var(--ease-out) forwards;animation-delay:var(--d,.3s)}
@keyframes fade-up-anim{to{opacity:1;transform:translateY(0)}}
