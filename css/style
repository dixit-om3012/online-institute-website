/* Popup Box */
.cert-overlay {
  position: fixed;
  inset: 0;
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1.25rem;
  background: rgba(4, 4, 4, 0.80);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease;
}
.cert-overlay.open {
  opacity: 1;
  pointer-events: all;
}

.cert-box {
  background: #ffffff;
  border-radius: 20px;
  box-shadow: 0 40px 100px rgba(0,0,0,0.4), 0 0 0 1px rgba(225,29,46,0.15);
  max-width: 700px;
  width: 100%;
  overflow: hidden;
  transform: scale(0.88) translateY(20px);
  opacity: 0;
  transition: transform 0.5s cubic-bezier(0.34,1.56,0.64,1), opacity 0.4s ease;
}
.cert-overlay.open .cert-box {
  transform: scale(1) translateY(0);
  opacity: 1;
}

.cert-topbar {
  height: 4px;
  background: linear-gradient(90deg, #E11D2E, #ff5566, #E11D2E);
  background-size: 200% 100%;
  animation: certShimmer 2.5s linear infinite;
}
@keyframes certShimmer {
  from { background-position: 0% 0%; }
  to   { background-position: 200% 0%; }
}

.cert-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-bottom: 1px solid rgba(0,0,0,0.07);
  background: #fafaf8;
  gap: 8px;
}
.cert-brand {
  display: flex;
  align-items: center;
  gap: 7px;
  flex: 1;
}
.cert-dot {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: #E11D2E;
  box-shadow: 0 0 8px rgba(225,29,46,0.5);
  animation: certPulse 2s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes certPulse {
  0%, 100% { transform: scale(1); }
  50%       { transform: scale(1.4); opacity: 0.7; }
}
.cert-brand-name {
  font-family: 'Clash Display', 'Bricolage Grotesque', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: #0a0a0a;
}
.cert-brand-name em {
  font-style: normal;
  color: #E11D2E;
}
.cert-badge {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #E11D2E;
  background: rgba(225,29,46,0.08);
  border: 1px solid rgba(225,29,46,0.2);
  padding: 3px 10px;
  border-radius: 50px;
  white-space: nowrap;
}
.cert-close {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 1px solid rgba(0,0,0,0.1);
  background: transparent;
  color: #888;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  flex-shrink: 0;
  transition: background 0.2s, color 0.2s, transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
.cert-close:hover {
  background: #E11D2E;
  color: #fff;
  border-color: #E11D2E;
  transform: rotate(90deg) scale(1.1);
}

.cert-imgwrap {
  position: relative;
  background: #f0efec;
  padding: 1.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cert-imgwrap::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,0,0,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,0,0,0.03) 1px, transparent 1px);
  background-size: 28px 28px;
  pointer-events: none;
}
.cert-img {
  display: block;
  width: 100%;
  max-height: 460px;
  object-fit: contain;
  border-radius: 10px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.12), 0 0 0 1px rgba(0,0,0,0.06);
  position: relative;
  z-index: 1;
  transition: transform 0.35s ease;
}
.cert-img:hover {
  transform: scale(1.015);
}

@media (max-width: 600px) {
  .cert-box { border-radius: 14px; }
  .cert-imgwrap { padding: 1rem; }
  .cert-img { max-height: 280px; }
  .cert-badge { display: none; }
}

