/* ─── TOKENS ─── */
:root{
  --red:#E11D2E;
  --red-dark:#b7121d;
  --red-alpha:rgba(225,29,46,.12);
  --red-glow:rgba(225,29,46,.25);
  --black:#0a0a0a;
  --off-white:#f8f8f6;
  --white:#ffffff;
  --surface:#f0efec;
  --border:rgba(0,0,0,.08);
  --border-dark:rgba(255,255,255,.08);
  --text-muted:#6b6b6b;
  --text-ghost:#a0a0a0;
  --nav-h:68px;
  --max:1200px;
  --r:14px;
  --r-lg:20px;
  --shadow-sm:0 2px 8px rgba(0,0,0,.06);
  --shadow-md:0 8px 32px rgba(0,0,0,.1);
  --shadow-lg:0 24px 64px rgba(0,0,0,.12);
  --ease:cubic-bezier(.25,.46,.45,.94);
  --ease-out:cubic-bezier(.16,1,.3,1);
  --ease-spring:cubic-bezier(.34,1.56,.64,1)
}

/* ─── TYPOGRAPHY ─── */
h1,h2,h3,h4{
  font-family:'Clash Display','Bricolage Grotesque',sans-serif;
  font-weight:700;line-height:1.1;letter-spacing:-0.03em
}
h1{font-size:clamp(3rem,7vw,6rem)}
h2{font-size:clamp(2rem,4vw,3.2rem)}
h3{font-size:1.25rem;letter-spacing:-0.02em}
h4{font-size:.95rem;letter-spacing:-.01em}
p{line-height:1.75;color:var(--text-muted)}
.text-red{color:var(--red)}

/* ─── LAYOUT ─── */
.container{max-width:var(--max);margin:0 auto;padding:0 2rem}
.section{padding:120px 0}

/* ─── NOISE OVERLAY ─── */
.noise-overlay{
  position:fixed;inset:0;z-index:9999;pointer-events:none;
  opacity:.025;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  background-size:200px 200px
}

/* ─── CUSTOM CURSOR ─── */
.cursor{
  position:fixed;width:36px;height:36px;border-radius:50%;
  border:1.5px solid var(--red);pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);transition:transform .18s var(--ease),opacity .18s,width .25s var(--ease),height .25s var(--ease);
  mix-blend-mode:multiply;opacity:0
}
.cursor-dot{
  position:fixed;width:5px;height:5px;border-radius:50%;
  background:var(--red);pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);transition:transform .06s;opacity:0
}
body:hover .cursor,body:hover .cursor-dot{opacity:1}
.cursor.hovering{width:60px;height:60px;background:var(--red-alpha);border-color:transparent}

/* ─── SCROLL REVEAL ─── */
.reveal-fade{
  opacity:0;transform:translateY(20px);
  transition:opacity .7s var(--ease-out),transform .7s var(--ease-out);
  transition-delay:var(--rd,0s)
}
.reveal-up{
  opacity:0;transform:translateY(36px);
  transition:opacity .75s var(--ease-out),transform .75s var(--ease-out);
  transition-delay:var(--rd,0s)
}
.reveal-fade.in,.reveal-up.in{opacity:1;transform:translateY(0)}

/* ─── SECTION HEADER ─── */
.section-header{text-align:center;margin-bottom:4.5rem}
.section-header h2{margin:.75rem 0 1.1rem}
.section-sub{max-width:520px;margin:0 auto;font-size:1.05rem}
.section-eyebrow{
  display:inline-block;font-size:.72rem;font-weight:600;letter-spacing:.12em;
  text-transform:uppercase;color:var(--red);
  border:1px solid rgba(225,29,46,.25);background:var(--red-alpha);
  padding:.3rem 1rem;border-radius:50px;margin-bottom:.5rem
}

/* ─── BUTTONS ─── */
.btn-primary{
  display:inline-flex;align-items:center;gap:.5rem;
  background:var(--red);color:#fff;
  padding:.875rem 1.875rem;border-radius:50px;
  font-size:.92rem;font-weight:600;border:none;
  transition:background .25s,transform .25s var(--ease-spring),box-shadow .25s
}
.btn-primary:hover{background:var(--red-dark);transform:translateY(-2px);box-shadow:0 8px 28px rgba(225,29,46,.35)}

.btn-ghost{
  display:inline-flex;align-items:center;gap:.5rem;
  background:transparent;color:rgba(255,255,255,.7);
  padding:.875rem 1.875rem;border-radius:50px;
  font-size:.92rem;font-weight:500;
  border:1.5px solid rgba(255,255,255,.22);
  transition:color .2s,border-color .2s,transform .2s var(--ease-spring)
}
.btn-ghost:hover{color:#fff;border-color:rgba(255,255,255,.6);transform:translateY(-2px)}

.btn-outline-dark{
  display:inline-flex;align-items:center;gap:.6rem;
  background:transparent;color:var(--black);
  padding:.825rem 1.75rem;border-radius:50px;
  font-size:.9rem;font-weight:600;
  border:1.5px solid var(--border);
  transition:background .2s,color .2s,border-color .2s,transform .2s var(--ease-spring)
}
.btn-outline-dark:hover{background:var(--black);color:#fff;border-color:var(--black);transform:translateY(-2px)}

/* ═══════════════════════════════════════════════
   NAVBAR
   ═══════════════════════════════════════════════ */
.navbar{
  position:fixed;top:0;left:0;right:0;z-index:500;
  height:var(--nav-h);
  transition:background .4s,box-shadow .4s,backdrop-filter .4s
}
.navbar.solid{
  background:rgba(248,248,246,.9);
  backdrop-filter:saturate(180%) blur(20px);
  -webkit-backdrop-filter:saturate(180%) blur(20px);
  box-shadow:0 1px 0 var(--border)
}
.navbar.dark-mode{--logo-text:#fff;--link-color:rgba(255,255,255,.7)}
.nav-inner{
  display:flex;align-items:center;justify-content:space-between;
  max-width:var(--max);margin:0 auto;padding:0 2rem;height:100%
}
/* Logo */
.logo{display:flex;align-items:center;gap:.65rem}
.logo-wordmark{display:flex;flex-direction:column;line-height:1}
.logo-name{font-family:'Clash Display',sans-serif;font-size:1.1rem;font-weight:700;letter-spacing:.04em;color:var(--logo-text,var(--black))}
.logo-sub{font-size:.62rem;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--text-ghost);margin-top:1px}
/* Nav links */
.nav-menu{display:flex;align-items:center;gap:.15rem}
.nav-link{
  font-size:.85rem;font-weight:500;padding:.5rem .7rem;border-radius:8px;
  color:var(--link-color,var(--text-muted));
  transition:color .2s,background .2s
}
.nav-link:hover{color:var(--black);background:rgba(0,0,0,.05)}
.navbar.dark-mode .nav-link:hover{color:#fff;background:rgba(255,255,255,.1)}
.nav-register{
  background:var(--red)!important;color:#fff!important;
  padding:.5rem 1.1rem!important;border-radius:50px!important;
  font-weight:600!important;margin-left:.5rem;
  transition:background .2s,transform .2s,box-shadow .2s!important
}
.nav-register:hover{background:var(--red-dark)!important;transform:translateY(-1px);box-shadow:0 4px 16px var(--red-glow)!important}
/* Burger */
.burger{
  display:none;flex-direction:column;gap:5px;
  background:none;border:none;padding:8px;z-index:600
}
.burger-bar{
  width:22px;height:1.8px;
  background:var(--burger-color,var(--black));
  border-radius:2px;
  transition:transform .35s var(--ease),opacity .35s,width .35s
}
.navbar.dark-mode .burger-bar{background:#fff}
.burger.open .burger-bar:nth-child(1){transform:translateY(6.8px) rotate(45deg)}
.burger.open .burger-bar:nth-child(2){opacity:0;width:0}
.burger.open .burger-bar:nth-child(3){transform:translateY(-6.8px) rotate(-45deg)}

/* ─── MOBILE DRAWER ─── */
.mobile-drawer{position:fixed;inset:0;z-index:490;pointer-events:none}
.mobile-drawer.open{pointer-events:all}
.drawer-backdrop{
  position:absolute;inset:0;background:rgba(0,0,0,.6);
  opacity:0;transition:opacity .4s var(--ease)
}
.mobile-drawer.open .drawer-backdrop{opacity:1}
.drawer-panel{
  position:absolute;top:0;right:0;width:min(360px,100vw);height:100%;
  background:#0a0a0a;padding:2rem;
  transform:translateX(100%);transition:transform .45s var(--ease-out)
}
.mobile-drawer.open .drawer-panel{transform:translateX(0)}
.drawer-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:3rem}
.drawer-close{
  background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);
  color:rgba(255,255,255,.6);border-radius:8px;padding:8px;
  transition:background .2s,color .2s
}
.drawer-close:hover{background:rgba(255,255,255,.12);color:#fff}
.drawer-links{display:flex;flex-direction:column;gap:.25rem}
.drawer-link{
  font-family:'Clash Display',sans-serif;font-size:1.5rem;font-weight:600;
  color:rgba(255,255,255,.4);padding:.5rem 0;
  letter-spacing:-.02em;
  transition:color .2s,transform .2s var(--ease-spring)
}
.drawer-link:hover{color:#fff;transform:translateX(8px)}
.drawer-register{
  margin-top:2rem;color:#fff!important;
  background:var(--red);padding:.85rem 1.75rem!important;
  border-radius:50px;font-size:1rem!important;font-weight:700!important;
  text-align:center;display:block
}

